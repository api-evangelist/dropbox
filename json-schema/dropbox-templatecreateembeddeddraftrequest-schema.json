      "description": "_t__Sub::FormFieldGroup::DESCRIPTION",
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SubFormFieldGroup"
      }
    },
    "form_field_rules": {
      "description": "_t__Sub::FormFieldRule::DESCRIPTION",
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SubFormFieldRule"
      }
