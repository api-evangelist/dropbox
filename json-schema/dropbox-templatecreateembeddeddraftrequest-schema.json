      "description": "_t__TemplateCreateEmbeddedDraft::MERGE_FIELDS",
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/SubMergeField"
      }
    },
    "message": {
      "description": "_t__TemplateCreateEmbeddedDraft::MESSAGE",
